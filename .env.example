# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=

# OpenRouter API Key (free at openrouter.ai)
OPENROUTER_API_KEY=

# Path to SQLite database file
DB_PATH=./data/bot.db

# Summary time window in hours (default: 24)
SUMMARY_HOURS=24

# Message retention period in days (default: 7)
RETENTION_DAYS=7

# Max messages to summarize (default: 250)
MAX_MESSAGES=250

# Rate limit in seconds between /summarize commands (default: 60)
RATE_LIMIT_SEC=60

# Show reply-to context in summaries (default: true)
# REPLY_THREADS=true

# OpenRouter model (default: meta-llama/llama-3.3-70b-instruct)
MODEL=meta-llama/llama-3.3-70b-instruct

# OpenRouter URL (optional, default: https://openrouter.ai/api/v1)
# OPENROUTER_URL=

# Comma-separated group IDs the bot is allowed to operate in.
# If empty or unset, the bot silently ignores ALL group messages.
# ALLOWED_GROUPS=-1001234567890,-1009876543210

# Comma-separated Telegram user IDs of bot admins (optional).
# Admins receive startup/shutdown alerts and can manage groups via /groups in private chat.
# Users must start a private chat with the bot first.
# ADMIN_USER_IDS=123456789,987654321

# Optional: route all traffic through a proxy (HTTP or SOCKS5)
# ALL_PROXY=socks5://user:pass@host:1080
# HTTPS_PROXY=http://host:3128
# NO_PROXY=localhost,127.0.0.1

# --- RAG (optional: chat history Q&A via @bot ask) ---
# Leave EMBEDDING_URL empty to disable RAG entirely.

# Embedding API endpoint (OpenAI-compatible)
# Examples:
#   OpenRouter: https://openrouter.ai/api/v1
#   Local Ollama: http://localhost:11434/v1
# EMBEDDING_URL=

# API key for the embedding endpoint (not needed for local Ollama)
# EMBEDDING_API_KEY=

# Embedding model name
# Examples:
#   OpenRouter: openai/text-embedding-3-small (1536 dims) or openai/text-embedding-3-large (3072 dims)
#   Ollama: nomic-embed-text (768 dims)
# EMBEDDING_MODEL=openai/text-embedding-3-small

# Embedding dimensions (0 = auto-detect from first API call)
# EMBEDDING_DIMS=0

# Qdrant gRPC address (default: localhost:6334)
# QDRANT_ADDR=localhost:6334

# Qdrant collection name (default: messages)
# QDRANT_COLLECTION=messages

# Number of top results for semantic search (default: 10)
# RAG_TOP_K=10

# Context expansion window in seconds around each hit (default: 300)
# RAG_CONTEXT_WINDOW=300
