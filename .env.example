# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=

# --- LLM Provider Configuration ---

# LLM mode: "completions" (default), "responses", or "oauth"
#   completions - OpenAI Chat Completions API (works with OpenRouter, LiteLLM, etc.)
#   responses   - OpenAI Responses API (direct OpenAI)
#   oauth       - OpenAI Codex subscription via OAuth (run: ./bot openai auth)
# LLM_MODE=completions

# API token for completions/responses modes
# (legacy OPENROUTER_API_KEY still works but is deprecated)
LLM_TOKEN=

# API endpoint (optional, defaults depend on mode):
#   completions: https://openrouter.ai/api/v1
#   responses:   https://api.openai.com/v1
#   oauth:       https://api.openai.com/v1
# LLM_ENDPOINT=

# LLM model (default: meta-llama/llama-3.3-70b-instruct)
MODEL=meta-llama/llama-3.3-70b-instruct

# --- OAuth Configuration (only for LLM_MODE=oauth) ---

# Directory to store OAuth tokens (default: ./data)
# OAUTH_TOKEN_DIR=./data

# OAuth client ID (default: Codex CLI client ID)
# OAUTH_CLIENT_ID=

# Codex client version sent in OAuth headers (default: 0.124.0).
# Increase if newer models return: "requires a newer version of Codex".
# OAUTH_CODEX_VERSION=0.124.0

# --- General Configuration ---

# Path to SQLite database file
DB_PATH=./data/bot.db

# Summary time window in hours (default: 24)
SUMMARY_HOURS=24

# Message retention period in days (default: 7)
RETENTION_DAYS=7

# Max messages to summarize (default: 250)
MAX_MESSAGES=250

# Rate limit in seconds between /summarize commands (default: 60)
RATE_LIMIT_SEC=60

# Show reply-to context in summaries (default: true)
# REPLY_THREADS=true

# Minimum length (chars) for a replied-to plain-text message to be summarized
# on its own when you reply with "@bot summarize" (default: 1000). Ignored when
# the replied message also has a link or image.
# REPLY_SUMMARIZE_MIN_CHARS=1000

# --- Image Recognition ---
#
# When enabled, photos and image documents posted in groups are described by
# the vision-capable LLM at summarize time and inlined into the summary as
# short Russian descriptions. Results are cached by Telegram's stable
# file_unique_id so the same image is never described twice.

# Enable image recognition: "auto" (detect from MODEL name), "true", "false"
# VISION_ENABLED=auto

# Use a different model for vision calls than for text (empty => same as MODEL)
# VISION_MODEL=

# Retention for cached image descriptions (days). Decoupled from
# RETENTION_DAYS because the same image often resurfaces months later.
# IMAGE_CACHE_DAYS=90

# Per-image size cap (bytes). Larger images are skipped.
# IMAGE_MAX_BYTES=5000000

# Max parallel vision calls per summarize run.
# IMAGE_DESCRIBE_CONCURRENCY=4

# Per-image vision call timeout (seconds).
# IMAGE_DESCRIBE_TIMEOUT_SEC=60

# HTTP client timeout for all LLM requests (cluster, summary, vision) in seconds.
# Vision-enriched prompts are larger; the default leaves headroom before the
# retry cycle kicks in.
# LLM_HTTP_TIMEOUT_SEC=180

# Comma-separated group IDs the bot is allowed to operate in.
# If empty or unset, the bot silently ignores ALL group messages.
# ALLOWED_GROUPS=-1001234567890,-1009876543210

# Comma-separated Telegram user IDs of bot admins (optional).
# Admins receive startup/shutdown alerts and can manage groups via /groups in private chat.
# Users must start a private chat with the bot first.
# ADMIN_USER_IDS=123456789,987654321

# Optional: route all traffic through a proxy (HTTP or SOCKS5)
# ALL_PROXY=socks5://user:pass@host:1080
# HTTPS_PROXY=http://host:3128
# NO_PROXY=localhost,127.0.0.1
